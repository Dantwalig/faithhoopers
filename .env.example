# Database — replace with your PostgreSQL connection string
# For local dev: postgresql://USER:PASSWORD@localhost:5432/faith_hoopers
# For hosted:    Use Supabase (supabase.com) or Neon (neon.tech) — both have free tiers
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/faith_hoopers"

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret-string"
NEXTAUTH_URL="http://localhost:3000"

# Bible API (optional but recommended)
# Get a free key at: https://scripture.api.bible
# Without a key, devotionals fall back to manual text entry
BIBLE_API_KEY="your-api-bible-key-here"
BIBLE_API_BASE="https://api.scripture.api.bible/v1"
# Default Bible version — "de4e12af7f28f599-01" is the KJV
BIBLE_VERSION_ID="de4e12af7f28f599-01"
